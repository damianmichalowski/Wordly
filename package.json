{
  "name": "wordly",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "vocabulary:seed": "tsx scripts/vocabulary-seed/src/index.ts",
    "vocabulary:seed:freedict": "tsx scripts/vocabulary-seed/src/index-freedict.ts",
    "vocabulary:seed:split-sql": "tsx scripts/vocabulary-seed/src/splitSeedSql.ts",
    "vocabulary:seed:apply-chunks": "tsx scripts/vocabulary-seed/src/applySqlChunks.ts",
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:sim": "expo run:ios -d \"iPhone 17\"",
    "ios:prebuild": "expo prebuild --platform ios --clean",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.99.3",
    "expo": "~55.0.8",
    "expo-apple-authentication": "~55.0.9",
    "expo-audio": "~55.0.9",
    "expo-auth-session": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "^55.0.18",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-speech": "^55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "wordly-widget-bridge": "file:./src/features/wordly-widget-bridge"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.1",
    "pg": "^8.14.1",
    "tsx": "^4.19.3",
    "typescript": "~5.9.2",
    "uuid": "^11.1.0"
  },
  "private": true
}
