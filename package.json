{
  "name": "wordly",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:ios": "expo start --dev-client --ios",
    "start:clean": "expo start --dev-client --clear",
    "clean:dev": "bash scripts/clean-dev.sh",
    "clean:dev:xcode": "bash scripts/clean-dev.sh --xcode",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:17pro": "expo run:ios --device \"iPhone 17 Pro\"",
    "ios:device": "expo run:ios --device",
    "ios:prebuild": "expo prebuild --platform ios --clean",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/query-async-storage-persister": "^5.96.2",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-query-persist-client": "^5.96.2",
    "expo": "~55.0.8",
    "expo-apple-authentication": "~55.0.9",
    "expo-audio": "~55.0.9",
    "expo-auth-session": "~55.0.9",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "^55.0.18",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-speech": "^55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "wordly-widget-bridge": "file:./src/features/wordly-widget-bridge"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
