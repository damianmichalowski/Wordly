# Skopiuj ten plik jako `.env` i uzupełnij wartości z Supabase: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres — Project Settings → Database → Connection string
#
# Sieć IPv4 (typowa domowa): **Session pooler** — w panelu „IPv4 compatible”, user `postgres.<project-ref>`,
# host `aws-….pooler.supabase.com`, port **taki jak w URI z panelu** (często 5432), pool_mode session.
# Najpewniej (hasło osobno — unikasz błędów parsowania URI / 28P01):
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]@aws-1-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_PASSWORD=hasło_z_Project_Settings_Database_Reset_password
#
# Albo jedna linia z hasłem w URI (+ ?sslmode=require). Logowanie do dashboardu supabase.com ≠ to hasło.
# DATABASE_URL=postgresql://postgres.[REF]:HASŁO@aws-1-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require
#
# Sieć IPv6: możesz użyć **Direct connection** (db.<ref>.supabase.co:5432), user `postgres`.
# Albo dokup **IPv4 add-on** jeśli potrzebujesz direct z IPv4.
#
# Osobna zmienna tylko gdy trzymasz dwa warianty:
# DATABASE_POOLER_URL=postgresql://postgres.xxxxx:HASŁO@aws-1-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require
#
# Gdy DATABASE_URL daje „Invalid URL” (hasło ze znakami @ # % : ? itd.) — rozdziel albo zakoduj hasło w URI:
# DATABASE_HOST=aws-1-eu-west-3.pooler.supabase.com
# DATABASE_USER=postgres.twoj_project_ref
# DATABASE_PASSWORD=twoje_haslo
# DATABASE_PORT=5432
# DATABASE_NAME=postgres

# Opcjonalnie — iOS: Team ID (10 znaków), żeby `@bacons/apple-targets` / prebuild nie ostrzegał
# i żeby Xcode miał DEVELOPMENT_TEAM. Zob. developer.apple.com → Membership.
# APPLE_TEAM_ID=XXXXXXXXXX

# Natywne Google Sign-In (iOS/Android) — patrz docs/SOCIAL_AUTH.md (A3a, C2, C3).
# Web client = ten sam co Client ID + Secret w Supabase → Providers → Google.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com
# Osobny klient OAuth typu „iOS” w Google Cloud (Bundle: com.wordly.mobile):
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-yyyyy.apps.googleusercontent.com
