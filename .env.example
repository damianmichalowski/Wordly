# Skopiuj ten plik jako `.env` i uzupełnij wartości z Supabase: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcjonalnie — connection string do Postgres (CLI, migracje, psql): Project Settings → Database.
# Na IPv4 często Session pooler; szczegóły w dokumentacji Supabase.
# DATABASE_URL=postgresql://…?sslmode=require

# Opcjonalnie — iOS: Team ID (10 znaków), żeby `@bacons/apple-targets` / prebuild nie ostrzegał
# i żeby Xcode miał DEVELOPMENT_TEAM. Zob. developer.apple.com → Membership.
# APPLE_TEAM_ID=XXXXXXXXXX

# Natywne Google Sign-In (iOS/Android) — patrz docs/SOCIAL_AUTH.md (A3a, C2, C3).
# Web client = ten sam co Client ID + Secret w Supabase → Providers → Google.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com
# Osobny klient OAuth typu „iOS” w Google Cloud (Bundle: com.wordly.mobile):
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-yyyyy.apps.googleusercontent.com
